{
	"window.title": "VC Müllheim - ${activeEditorShort}",
	"editor.defaultFormatter": "oxc.oxc-vscode",
	"[json]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[css]": {
		"editor.defaultFormatter": "vscode.css-language-features"
	},
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features"
	},
	"editor.codeActionsOnSave": {
		"source.removeUnusedImports": "explicit"
	},
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": false,
	"files.watcherExclude": {
		"**/routeTree.gen.ts": true
	},
	"search.exclude": {
		"**/routeTree.gen.ts": true
	},
	"files.readonlyInclude": {
		"**/routeTree.gen.ts": true
	},
	"js/ts.tsdk.path": "node_modules/typescript/lib",
	"chat.useNestedAgentsMdFiles": true,
	"chat.tools.terminal.autoApprove": {
		"/^vp (run )?(test|check(--fix)?|lint|verify(:all)?|cdk:synth(:all)?|deps-check)(\\s+[\\w./\\-:*=]+)*(\\s+2>&1)?(\\s*\\|\\s*(head|tail|cat|grep|wc)(\\s+[\\w./\\-*=]+)*)?$/": true,
		"/^bun (run )?(testcheck(:fix)?|verify(:all)?|cdk:synth(:all)?|deps-check)(\\s+[\\w./\\-:*=]+)*(\\s+2>&1)?(\\s*\\|\\s*(head|tail|cat|grep|wc)(\\s+[\\w./\\-*=]+)*)?$/": true,
		"/\\.github\\/skills\\/sams-api\\/sams\\.ts/": true
	},
	"github-actions.workflows.pinned.workflows": [".github/workflows/cdk-deploy.yml"]
}
