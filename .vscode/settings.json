{
	"window.title": "VC Müllheim - ${activeEditorShort}",
	"editor.defaultFormatter": "biomejs.biome",
	"[css]": {
		"editor.defaultFormatter": "vscode.css-language-features"
	},
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features"
	},
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"editor.codeActionsOnSave": {
		"source.organizeImports.biome": "explicit",
		"source.fixAll.biome": "explicit",
	},
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": false,
	"files.watcherExclude": {
		"**/routeTree.gen.ts": true
	},
	"search.exclude": {
		"**/routeTree.gen.ts": true
	},
	"files.readonlyInclude": {
		"**/routeTree.gen.ts": true
	},
	"typescript.tsdk": "node_modules/typescript/lib",
	"vs-browser.favourites.list": {
		"localhost (website)": "http://localhost:3080",
		"localhost (cms)": "http://localhost:3081"
	},
	"chat.useNestedAgentsMdFiles": true,
	"chat.tools.terminal.autoApprove": {
		"/^bun (run )(test|typecheck|lint|check(:fix)|verify(:all)|cdk:synth(:all)|tsc(--noEmit)|deps-check)(\\s+[\\w./\\-:*=]+)*(\\s+2>&1)?(\\s*\\|\\s*(head|tail|cat|grep|wc)(\\s+[\\w./\\-*=]+)*)?$/": true,
		"/\\.agents\\/skills\\/sams-api\\/sams\\.ts/": true,
	},
	"github-actions.workflows.pinned.workflows": [
		".github/workflows/cdk-deploy.yml"
	]
}
