{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"types": ["vite/client", "bun-types"],
		"baseUrl": "../..",
		"paths": {
			"@/*": ["./*"],
			"@webapp/*": ["apps/webapp/src/*"],
			"@lib/*": ["lib/*"],
			"@lambda/*": ["lambda/*"],
			"@utils/*": ["utils/*"],
			"@data/*": ["data/*"],
			"@codegen/*": ["codegen/*"],
			"@project.config": ["project.config.ts"]
		}
	},
	"include": ["src", "vite.config.ts"],
	"exclude": ["node_modules"]
}
