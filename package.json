{
	"name": "vcmuellheim.de",
	"version": "2.0.0",
	"homepage": "https://vcmuellheim.de",
	"bugs": {
		"url": "https://github.com/terijaki/vcmuellheim/issues"
	},
	"author": {
		"name": "Björn Kohnen",
		"email": "bjoern@vcmuellheim.de"
	},
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --cwd apps/webapp vite dev --port 3080",
		"build": "bun --cwd apps/webapp vite build",
		"start": "node apps/webapp/.output/server/index.mjs",
		"lint": "biome lint",
		"check": "biome check",
		"check:fix": "biome check --fix",
		"typecheck": "tsc --noEmit",
		"test": "AGENT=1 bun test",
		"db:seed": "bun run scripts/db-seed.ts",
		"db:seed:sams": "bun run scripts/data-trigger-syncs.ts",
		"sams:update": "bun run codegen/sams/generate-client.ts",
		"verify:all": "bun biome check --fix && bun typecheck && AGENT=1 bun test",
		"cdk": "cdk --profile vcmuellheim",
		"cdk:deploy": "cdk deploy --profile vcmuellheim --require-approval=never",
		"cdk:deploy:all": "cdk deploy --all --profile vcmuellheim --require-approval=never",
		"cdk:deploy:prod": "CDK_ENVIRONMENT=prod cdk deploy --all --profile vcmuellheim",
		"cdk:synth": "cdk synth --profile vcmuellheim",
		"cdk:synth:all": "cdk synth --all --profile vcmuellheim",
		"cdk:synth:prod": "CDK_ENVIRONMENT=prod cdk synth --all --profile vcmuellheim",
		"cdk:diff": "cdk diff --profile vcmuellheim",
		"cdk:diff:all": "cdk diff --all --profile vcmuellheim",
		"cdk:diff:prod": "CDK_ENVIRONMENT=prod cdk diff --all --profile vcmuellheim",
		"cdk:destroy": "cdk destroy --profile vcmuellheim --require-approval=never",
		"cdk:destroy:all": "cdk destroy --all --profile vcmuellheim --require-approval=never",
		"cdk:destroy:prod": "CDK_ENVIRONMENT=prod cdk destroy --all --profile vcmuellheim",
		"cdk:bootstrap": "cdk bootstrap --profile vcmuellheim",
		"deps-check": "bun outdated --recursive"
	},
	"dependencies": {
		"@aws-sdk/client-dynamodb": "^3.1009.0",
		"@aws-sdk/client-s3": "^3.1009.0",
		"@aws-sdk/client-ses": "^3.1009.0",
		"@aws-sdk/lib-dynamodb": "^3.1009.0",
		"@aws-sdk/s3-request-presigner": "^3.1009.0",
		"@mantine/core": "^8.3.17",
		"@mantine/dates": "^8.3.17",
		"@mantine/dropzone": "^8.3.9",
		"@mantine/hooks": "^8.3.17",
		"@mantine/notifications": "^8.3.9",
		"@mantine/tiptap": "^8.3.9",
		"@middy/core": "^6.4.5",
		"@rolldown/plugin-babel": "^0.2.1",
		"@sentry/aws-serverless": "^10.43.0",
		"@sentry/react": "^10.43.0",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.160.0",
		"@tanstack/react-start": "^1.166.8",
		"@tiptap/extension-image": "^2.10.4",
		"@tiptap/extension-link": "^2.10.4",
		"@tiptap/react": "^2.10.4",
		"@tiptap/starter-kit": "^2.10.4",
		"better-auth": "1.5.5",
		"dayjs": "^1.11.20",
		"lucide-react": "^0.577.0",
		"nitro": "^3.0.260311-beta",
		"num-words-de": "^1.1.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-fast-marquee": "^1.6.5",
		"react-icons": "^5.6.0",
		"react-world-flags": "^1.6.0",
		"superjson": "^2.2.6",
		"ts-ics": "^2.4.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@aws-cdk/aws-lambda-nodejs": "^1.204.0",
		"@aws-lambda-powertools/logger": "^2.31.0",
		"@aws-lambda-powertools/tracer": "^2.31.0",
		"@aws-sdk/client-lambda": "^3.1009.0",
		"@biomejs/biome": "2.3.8",
		"@hey-api/openapi-ts": "^0.92.4",
		"@sentry/vite-plugin": "^5.1.1",
		"@tanstack/router-plugin": "^1.160.0",
		"@types/aws-lambda": "^8.10.161",
		"@types/babel__core": "^7.20.5",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6",
		"aws-cdk-lib": "^2.243.0",
		"aws-sdk-client-mock": "^4.1.0",
		"aws-xray-sdk-core": "^3.12.0",
		"babel-plugin-react-compiler": "^1.0.0",
		"bun-types": "^1.3.9",
		"constructs": "^10.5.1",
		"postcss": "^8.4.49",
		"postcss-preset-mantine": "^1.17.0",
		"postcss-simple-vars": "^7.0.1",
		"typescript": "^5.9.3",
		"vite": "^8"
	}
}
